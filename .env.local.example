# ============================================================
# VALUENCE OS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic / Claude ────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App URL (change for production) ──────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional Integrations (add when ready) ───────────────────

# Exa.ai (sourcing intelligence + per-company research)
# Get a key at: https://exa.ai
# EXA_API_KEY=

# Fireflies.ai (meeting transcript sync)
# Get a key at: https://app.fireflies.ai/integrations
# Then configure the webhook in Fireflies: Settings → Webhooks → add:
#   https://your-app.vercel.app/api/webhooks/fireflies-direct
# FIREFLIES_API_KEY=

# Voyage AI (pgvector semantic search in AI chat)
# Anthropic's embedding partner — 1536-dim vectors matching the DB schema
# Get a key at: https://dash.voyageai.com
# VOYAGE_API_KEY=

# Firecrawl (web scraping)
# FIRECRAWL_API_KEY=

# Microsoft Graph API (Outlook integration)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=
